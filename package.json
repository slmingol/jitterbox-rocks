{
  "name": "jitterbox-rocks",
  "version": "1.1.3",
  "description": "A comprehensive music trivia game with daily challenges and practice mode",
  "main": "index.js",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "nodemon server/index.ts",
    "client": "cd client && npm start",
    "build": "cd client && npm run build",
    "install-all": "npm install && cd client && npm install",
    "seed": "ts-node server/scripts/seed.ts",
    "generate-billboard-games": "ts-node server/scripts/generateBillboardGames.ts",
    "collect-data": "ts-node server/scripts/collectAllData.ts",
    "start": "node dist/server/index.js"
  },
  "keywords": [
    "music",
    "trivia",
    "game"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "better-sqlite3": "^9.2.2",
    "uuid": "^9.0.1",
    "multer": "^1.4.5-lts.1",
    "date-fns": "^2.30.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.20",
    "@types/cors": "^2.8.15",
    "@types/node": "^20.8.9",
    "@types/multer": "^1.4.9",
    "@types/better-sqlite3": "^7.6.8",
    "@types/uuid": "^9.0.7",
    "typescript": "^5.2.2",
    "ts-node": "^10.9.1",
    "nodemon": "^3.0.1",
    "concurrently": "^8.2.2"
  }
}
